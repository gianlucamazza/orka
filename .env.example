# ── Docker Compose variables (interpolated by compose) ──────────────

# Redis password shared between the redis service and orka-server
REDIS_PASSWORD=orka-dev

# OCI image labels (set automatically by `just docker-build`)
# BUILD_DATE=
# VCS_REF=
# VERSION=dev

# ── Orka runtime overrides (ORKA__ prefix, __ = nesting) ───────────
# These override values from orka.toml inside the container.
# docker-compose.yml already sets the most common ones; uncomment below
# only if you need to diverge from the compose defaults.

# ORKA__SERVER__HOST=0.0.0.0
# ORKA__SERVER__PORT=8080
# ORKA__REDIS__URL=redis://:orka-dev@redis:6379
# ORKA__LOGGING__LEVEL=info
# ORKA__LOGGING__JSON=true
# ORKA__ADAPTERS__CUSTOM__HOST=0.0.0.0
# ORKA__ADAPTERS__CUSTOM__PORT=8081
# ORKA__ADAPTERS__TELEGRAM__MODE=polling
# ORKA__ADAPTERS__TELEGRAM__WEBHOOK_URL=https://example.com/telegram/webhook
# ORKA__ADAPTERS__TELEGRAM__WEBHOOK_PORT=8443
# ORKA__ADAPTERS__TELEGRAM__PARSE_MODE=HTML
# ORKA__WORKER__CONCURRENCY=4
# ORKA__LLM__DEFAULT_MODEL=claude-sonnet-4-6
# ORKA__LLM__DEFAULT_MAX_TOKENS=8192
# ORKA__LLM__PROVIDERS__0__NAME=anthropic
# ORKA__LLM__PROVIDERS__0__PROVIDER=anthropic
# ORKA__LLM__PROVIDERS__0__MODEL=claude-sonnet-4-6
# ORKA__LLM__PROVIDERS__0__API_KEY_SECRET=llm/anthropic

# ── LLM API keys (env var fallback when not stored in Redis) ──────

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── Web search API keys ──────────────────────────────────────────

# TAVILY_API_KEY=tvly-...
# BRAVE_API_KEY=BSA...

# ── Adapter tokens ───────────────────────────────────────────────

# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=xoxb-...
# WHATSAPP_ACCESS_TOKEN=

# ── Rust / debugging ───────────────────────────────────────────────

# RUST_LOG=debug
