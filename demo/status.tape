Output demo/orka-status.mp4
Set Theme "Catppuccin Mocha"
Set Width 960
Set Height 600
Set FontSize 14
Set TypingSpeed 50ms

# Requires ORKA_SERVER_URL to point at a live backend.
Type "orka status"
Enter
Sleep 3s

Type "orka skill list"
Enter
Sleep 3s

Type "orka session list --limit 5"
Enter
Sleep 3s
