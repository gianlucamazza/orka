Output demo/orka-chat.mp4
Set Theme "Catppuccin Mocha"
Set Width 960
Set Height 600
Set FontSize 14
Set TypingSpeed 50ms

# Requires ORKA_SERVER_URL to point at a live backend with OS skills enabled.
Type "orka chat --no-workspace"
Enter
Sleep 3s

Type "List the running systemd services and show disk usage on / in a short summary."
Enter
Sleep 25s

Type "/quit"
Enter
Sleep 2s
